-- HÀM ĐẸP HÓA HIỆU ỨNG DI CHUỘT (HOVER EFFECT)
local function applyHoverEffect(button, stroke)
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Button, TextColor3 = Colors.Accent}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Colors.Accent}):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Button, TextColor3 = Colors.Text}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Colors.Border}):Play()
    end)
end
applyHoverEffect(saveBtn, saveStroke)
applyHoverEffect(tpBtn, tpStroke)

-- HIỆU ỨNG TWEEN ĐÓNG / MỞ MENU MƯỢT MÀ
local isTweening = false
toggleBtn.MouseButton1Click:Connect(function()
    if isTweening then return end
    isTweening = true
    if frame.Visible then
        local closeTween = TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1})
        closeTween:Play()
        closeTween.Completed:Connect(function()
            frame.Visible = false
            isTweening = false
        end)
    else
        frame.Size = UDim2.new(0, 0, 0, 0)
        frame.BackgroundTransparency = 1
        frame.Visible = true
        local openTween = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = originalSize, BackgroundTransparency = 0})
        openTween:Play()
        openTween.Completed:Connect(function()
            isTweening = false
        end)
    end
end)

-- THÔNG BÁO (NOTIFY)
local function notify(text)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = "BlackHub Teleport",
			Text = text,
			Duration = 3
		})
	end)
end

-- XỬ LÝ SỰ KIỆN LƯU VỊ TRÍ
saveBtn.MouseButton1Click:Connect(function()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		savedPosition = char.HumanoidRootPart.CFrame
		notify("Đã lưu vị trí thành công!")
	end
end)

-- XỬ LÝ SỰ KIỆN DỊCH CHUYỂN
tpBtn.MouseButton1Click:Connect(function()
	if tpLocked then
		notify("⚠️ Thao tác thất bại: Đã bị khóa dịch chuyển!")
		return
	end

	local char = player.Character
	if savedPosition and char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = savedPosition
		notify("Đã dịch chuyển tới điểm lưu!")
	else
        notify("❌ Bạn chưa lưu vị trí nào!")
	end
end)

-- XỬ LÝ LỆNH CHAT COMMANDS
local function handleCommand(plr, msg)
	if plr.Name ~= OWNER_NAME then
		return
	end

	local target = msg:match("^/tp%s+(%S+)$")
	if target and target:lower() == player.Name:lower() then
		tpLocked = true
		notify("🔒 Tính năng dịch chuyển đã bị Khóa từ xa bởi Chủ sở hữu!")
		return
	end

	local unlockTarget = msg:match("^/unlock%s+(%S+)$")
	if unlockTarget and unlockTarget:lower() == player.Name:lower() then
		tpLocked = false
		notify("🔓 Tính năng dịch chuyển đã được Mở khóa từ xa!")
		return
	end
end

for _, plr in ipairs(Players:GetPlayers()) do
	plr.Chatted:Connect(function(msg)
		handleCommand(plr, msg)
	end)
end

Players.PlayerAdded:Connect(function(plr)
	plr.Chatted:Connect(function(msg)
		handleCommand(plr, msg)
	end)
end)
