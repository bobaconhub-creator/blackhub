    Button = Color3.fromRGB(30, 30, 30),           -- Nền nút mặc định
    Accent = Color3.fromRGB(140, 40, 255),         -- Tím Neon sáng rực
    Text = Color3.fromRGB(230, 230, 230),          -- Văn bản chính (gần trắng)
    Border = Color3.fromRGB(45, 45, 45)            -- Viền nhẹ khi nút ở trạng thái thường
