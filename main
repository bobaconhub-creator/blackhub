    MainBg = Color3.fromRGB(15, 12, 22),       -- Tối ưu lại nền đen sâu hơn để nổi bật viền light
    TabBg = Color3.fromRGB(25, 18, 35),
    TabActive = Color3.fromRGB(110, 40, 230),
    TabInActive = Color3.fromRGB(35, 25, 50),
    ElementBg = Color3.fromRGB(32, 22, 48),
    Text = Color3.fromRGB(230, 220, 255),
    Accent = Color3.fromRGB(150, 60, 255),
    Alert = Color3.fromRGB(255, 60, 150),
    VIP = Color3.fromRGB(190, 80, 255),
    
    -- Màu cho hiệu ứng chuyển sắc viền (Tím nhạt -> Tím đậm)
    LightPurple = Color3.fromRGB(210, 150, 255),
    DarkPurple = Color3.fromRGB(75, 15, 140)
}

