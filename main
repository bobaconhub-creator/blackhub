-- Khởi tạo settings hệ thống
if not getgenv().BaconSettings then
    getgenv().BaconSettings = {
        SpeedToggle = true, InfJump = false, Noclip = false,
        HitboxAll = false, HitboxTeam = false,
        ESPAll = false, ESPTeam = false,
        Speed = 30, HitboxSize = 20, HitboxTransparency = 0.7,
        HealthDisplay = false,
        HitboxBlacklist = {["ehfphvg362"] = true},
        ESPBlacklist = {["ehfphvg362"] = true},
        VIP_Status = {
            IsUnlocked = false,
            KeyType = "", 
            TimeRemaining = 0,
            LastSavedTime = os.time()
        }
    }
end
local settings = getgenv().BaconSettings

local player = game.Players.LocalPlayer
local uis = game:GetService("UserInputService")
local rs = game:GetService("RunService")
local players = game:GetService("Players")
local tweenService = game:GetService("TweenService")
local httpService = game:GetService("HttpService")

-- Đọc/Ghi File để lưu dữ liệu VIP địa phương
local function saveVIPData()
    if writefile then
        pcall(function()
            writefile("BaconVIP_Config.json", httpService:JSONEncode(settings.VIP_Status))
        end)
    end
end

local function loadVIPData()
    if readfile and isfile and isfile("BaconVIP_Config.json") then
        local success, data = pcall(function()
            return httpService:JSONDecode(readfile("BaconVIP_Config.json"))
        end)
        if success and data then
            if data.IsUnlocked and data.KeyType == "Normal10" then
                local timePassed = os.time() - data.LastSavedTime
                data.TimeRemaining = math.max(0, data.TimeRemaining - timePassed)
                if data.TimeRemaining <= 0 then
                    data.IsUnlocked = false
                    data.KeyType = ""
                end
            end
            settings.VIP_Status = data
        end
    end
end
loadVIPData()

local playerCache = {}

