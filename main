        healthStroke.Color = Colors.Accent
        healthBtn.Text = "ON"
        for _, p in pairs(players:GetPlayers()) do
            if p ~= player and p.Character and (settings.ESPAll or settings.ESPTeam) then createHealthBar(p) end
        end
    else
        tweenService:Create(healthBtn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Button, TextColor3 = Colors.Text}):Play()
        healthStroke.Color = Colors.Border
        healthBtn.Text = "OFF"
        for _, p in pairs(players:GetPlayers()) do removeHealthBar(p) end
    end
end)

