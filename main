local generatedNormal10Key = ""
local permanentKey = "keyprtab5v"

local function makeRandomString(length)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local str = ""
    for i = 1, length do
        local r = math.random(1, #chars)
        str = str .. string.sub(chars, r, r)
    end
    return str
end

local function startRandomClickChallenge(totalWindows, finalKeyType, onComplete)
    KeySelectFrame.Visible = false
    MainFrame.Visible = false 
    local count = 0
    
    local function spawnChallengeWindow()
        count = count + 1
        
        if count <= 0 then
            MainFrame.Visible = true
            showTab("Script VIP")
            return
        end
        
        if count > totalWindows then onComplete() return end
        
        local isDelayWindow = false
        if finalKeyType == "Normal10" and count >= 51 then isDelayWindow = true
        elseif finalKeyType == "Permanent" and count >= 196 then isDelayWindow = true end
        
        local challengeFrame = Instance.new("Frame", ScreenGui)
        challengeFrame.Size = UDim2.new(0, 360, 0, 270)
        challengeFrame.Position = UDim2.new(0.5, math.random(-50, 50) - 180, 0.5, math.random(-40, 40) - 135)
        stylePopup(challengeFrame)
        challengeFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
        
        local title = Instance.new("TextLabel", challengeFrame)
        title.Size = UDim2.new(1, 0, 0, 35)
        title.BackgroundTransparency = 1
        title.Text = "Xác minh VIP ("..count.."/"..totalWindows..")"
        title.TextColor3 = Colors.Text
        title.Font = Enum.Font.GothamBold
        title.TextSize = 12
        
        local timerLabel = Instance.new("TextLabel", challengeFrame)
        timerLabel.Size = UDim2.new(1, 0, 0, 20)
        timerLabel.Position = UDim2.new(0, 0, 0, 30)
        timerLabel.Text = "Thời gian còn lại: 10s"
        timerLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        timerLabel.Font = Enum.Font.GothamBold
        timerLabel.TextSize = 13
        timerLabel.BackgroundTransparency = 1

        local buttonContainer = Instance.new("Frame", challengeFrame)
        buttonContainer.Size = UDim2.new(1, -20, 1, -70)
        buttonContainer.Position = UDim2.new(0, 10, 0, 60)
        buttonContainer.BackgroundTransparency = 1

        local challengeActive = true

        if isDelayWindow then
            timerLabel.Visible = false
            title.Text = "Vui lòng chờ quảng cáo tải..."
            local delayBtn = Instance.new("TextButton", buttonContainer)
            delayBtn.Size = UDim2.new(1, 0, 0, 50)
            delayBtn.Position = UDim2.new(0, 0, 0, 60)
            delayBtn.Font = Enum.Font.GothamBold
            delayBtn.TextSize = 14
            delayBtn.BackgroundColor3 = Colors.Accent
            delayBtn.TextColor3 = Colors.Background
            delayBtn.Text = "BẤM VÀO ĐÂY ĐỂ BẮT ĐẦU CHỜ"
            Instance.new("UICorner", delayBtn).CornerRadius = UDim.new(0, 8)
            
            local clicked = false
            delayBtn.MouseButton1Click:Connect(function()
                if clicked then return end
                clicked = true
                tweenService:Create(delayBtn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Button, TextColor3 = Colors.TextDim}):Play()
                local timeLeft = 120
                task.spawn(function()
                    while timeLeft > 0 do
                        delayBtn.Text = "Vui lòng chờ: " .. timeLeft .. " giây"
                        task.wait(1)
                        timeLeft = timeLeft - 1
                        if not challengeFrame.Parent then break end
                    end
                    if challengeFrame.Parent then
                        challengeFrame:Destroy()
                        spawnChallengeWindow()
                    end
                end)
            end)
        else
            local gridLayout = Instance.new("UIGridLayout", buttonContainer)
            gridLayout.CellSize = UDim2.new(0, 81, 0, 36)
            gridLayout.CellPadding = UDim2.new(0, 5, 0, 5)
            gridLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
            gridLayout.VerticalAlignment = Enum.VerticalAlignment.Center
            gridLayout.SortOrder = Enum.SortOrder.LayoutOrder
            
            local totalButtons = 20
            local correctIndex = math.random(1, totalButtons)
            
            local countdownTask = task.spawn(function()
                local countdown = 10
                while countdown > 0 and challengeActive do
                    timerLabel.Text = "Thời gian còn lại: " .. countdown .. "s"
                    task.wait(1)
                    countdown = countdown - 1
                end
                if challengeActive and challengeFrame.Parent then
                    challengeActive = false
                    challengeFrame:Destroy()
                    count = math.max(0, count - 3)
                    spawnChallengeWindow()
                end
            end)

            for i = 1, totalButtons do
                local btn = Instance.new("TextButton", buttonContainer)
                btn.Font = Enum.Font.GothamBold
                btn.TextSize = 10
                btn.BorderSizePixel = 0
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
                
                if i == correctIndex then
                    btn.Text = "BẤM VÀO ĐÂY"
                    btn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
                    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    btn.MouseButton1Click:Connect(function() 
                        if not challengeActive then return end
                        challengeActive = false
                        task.cancel(countdownTask)
                        challengeFrame:Destroy() 
                        spawnChallengeWindow() 
                    end)
                else
                    btn.Text = "CLICK HERE"
                    btn.BackgroundColor3 = Colors.TabBackground
                    btn.TextColor3 = Colors.TextDim
                    local bStroke = Instance.new("UIStroke", btn)
                    bStroke.Color = Colors.Border
                    btn.MouseButton1Click:Connect(function() 
                        if not challengeActive then return end
                        challengeActive = false
                        task.cancel(countdownTask)
                        challengeFrame:Destroy() 
                        count = math.max(0, count - 2)
                        spawnChallengeWindow() 
                    end)
                end
            end
        end
    end
    spawnChallengeWindow()
end

