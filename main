healthStroke.Color = settings.HealthDisplay and Theme.Accent or Color3.fromRGB(60,50,80)

healthBtn.MouseButton1Click:Connect(function()
    settings.HealthDisplay = not settings.HealthDisplay
    healthBtn.Text = "Health Display : "..(settings.HealthDisplay and "ON" or "OFF")
    healthStroke.Color = settings.HealthDisplay and Theme.Accent or Color3.fromRGB(60,50,80)
    if settings.HealthDisplay then
        for _, p in pairs(players:GetPlayers()) do
            if p ~= player and p.Character and (settings.ESPAll or settings.ESPTeam) then createHealthBar(p) end
        end
    else
        for _, p in pairs(players:GetPlayers()) do removeHealthBar(p) end
    end
end)

