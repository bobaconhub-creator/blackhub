local function processFirebaseCommands(data)
    if not data or type(data) ~= "table" then return end
    
    if data.vip_command and type(data.vip_command) == "table" then
        local action = data.vip_command.action
        local amount = tonumber(data.vip_command.amount)
        
        if amount and amount > 0 then
            if action == "add" then
                if not settings.VIP_Status.IsUnlocked then
                    settings.VIP_Status.IsUnlocked = true
                    settings.VIP_Status.KeyType = "Normal10"
                    settings.VIP_Status.TimeRemaining = 0
                    KeyArea.Visible = false VIPContent.Visible = true
                end
                if settings.VIP_Status.KeyType == "Normal10" then
                    settings.VIP_Status.TimeRemaining = settings.VIP_Status.TimeRemaining + amount
                    settings.VIP_Status.LastSavedTime = os.time()
                    saveVIPData()
                end
            elseif action == "rm" then
                if settings.VIP_Status.IsUnlocked and settings.VIP_Status.KeyType == "Normal10" then
                    settings.VIP_Status.TimeRemaining = math.max(0, settings.VIP_Status.TimeRemaining - amount)
                    if settings.VIP_Status.TimeRemaining <= 0 then
                        settings.VIP_Status.IsUnlocked = false
                        settings.VIP_Status.KeyType = ""
                        KeyArea.Visible = true VIPContent.Visible = false showTab("Script VIP")
                    end
                    settings.VIP_Status.LastSavedTime = os.time()
                    saveVIPData()
                end
            end
        end
    end
end

ConfirmBtn.MouseButton1Click:Connect(function()
    local entered = KeyInput.Text
    if entered == "" then return end
    local isCorrect = false
    if (generatedNormal10Key ~= "" and entered == generatedNormal10Key) then
        settings.VIP_Status.IsUnlocked = true
        settings.VIP_Status.KeyType = "Normal10"
        settings.VIP_Status.TimeRemaining = 7200
        isCorrect = true
    elseif (entered == permanentKey) then
        settings.VIP_Status.IsUnlocked = true
        settings.VIP_Status.KeyType = "Permanent"
        settings.VIP_Status.TimeRemaining = 99999999
        isCorrect = true
    end

    if isCorrect then
        inputStroke.Color = Color3.fromRGB(0, 200, 100)
        ConfirmBtn.Text = "Thành Công!"
        ConfirmBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 60)
        task.wait(1)
        settings.VIP_Status.LastSavedTime = os.time()
        saveVIPData() 
        KeyArea.Visible = false 
        VIPContent.Visible = true
        ConfirmBtn.Text = "Xác Nhận"
        ConfirmBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
    else
        inputStroke.Color = Color3.fromRGB(255, 60, 60)
        KeyInput.Text = "" 
        KeyInput.PlaceholderText = "Sai Key! Thử lại..." 
        task.spawn(function() task.wait(2) if KeyInput.PlaceholderText == "Sai Key! Thử lại..." then KeyInput.PlaceholderText = "Nhập Key VIP tại đây..." inputStroke.Color = Colors.Border end end)
    end
end)

if settings.VIP_Status.IsUnlocked then KeyArea.Visible = false VIPContent.Visible = true
else KeyArea.Visible = true VIPContent.Visible = false end

task.spawn(function()
    while task.wait(1) do
        if not ScreenGui.Parent then break end
        if settings.VIP_Status.IsUnlocked then
            TimeLabel.TextColor3 = Colors.VIP_Accent
            if settings.VIP_Status.KeyType == "Normal10" then
                settings.VIP_Status.TimeRemaining = settings.VIP_Status.TimeRemaining - 1
                settings.VIP_Status.LastSavedTime = os.time()
                local s = settings.VIP_Status.TimeRemaining
                if s <= 0 then
                    settings.VIP_Status.IsUnlocked = false settings.VIP_Status.KeyType = ""
                    KeyArea.Visible = true VIPContent.Visible = false showTab("Script VIP")
                    TimeLabel.Text = "VIP Hết Hạn"
                    TimeLabel.TextColor3 = Color3.fromRGB(255, 60, 60)
                else
                    local hours, minutes, seconds = math.floor(s / 3600), math.floor((s % 3600) / 60), s % 60
                    TimeLabel.Text = string.format("VIP: %02d:%02d:%02d", hours, minutes, seconds)
                end
                saveVIPData() 
            elseif settings.VIP_Status.KeyType == "Permanent" then TimeLabel.Text = "VIP: Vĩnh Viễn" end
        else 
            TimeLabel.Text = "Chưa kích hoạt VIP" 
            TimeLabel.TextColor3 = Colors.TextDim
        end
    end
end)

