local tabBarPadding = Instance.new("UIPadding", TabBar)
tabBarPadding.PaddingTop = UDim.new(0, 2)
tabBarPadding.PaddingBottom = UDim.new(0, 2)

showTab("Main")

local UI_Elements = {} -- Lưu các element để sync

local function createToggleButton(tabName, text, settingKey, callback)
    local container = Instance.new("Frame", Tabs[tabName].Scroll)
    container.Size = UDim2.new(1, -20, 0, 40)
    container.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, -60, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Colors.Text
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(0, 50, 0, 26)
    btn.Position = UDim2.new(1, -50, 0.5, -13)
    btn.BackgroundColor3 = Colors.Button
    btn.Text = ""
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1,0)
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Color = Colors.Border
    btnStroke.Thickness = 1

    local circle = Instance.new("Frame", btn)
    circle.Size = UDim2.new(0, 20, 0, 20)
    circle.Position = UDim2.new(0, 3, 0.5, -10)
    circle.BackgroundColor3 = Colors.TextDim
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1,0)

    local function updateUI(on)
        if on then
            tweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.AccentDark}):Play()
            tweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(1, -23, 0.5, -10), BackgroundColor3 = Colors.Text}):Play()
            btnStroke.Color = Colors.Accent
        else
            tweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Button}):Play()
            tweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(0, 3, 0.5, -10), BackgroundColor3 = Colors.TextDim}):Play()
            btnStroke.Color = Colors.Border
        end
    end

    btn.MouseButton1Click:Connect(function()
        settings[settingKey] = not settings[settingKey]
        updateUI(settings[settingKey])
        callback(settings[settingKey])
    end)

    if settings[settingKey] then
        callback(true)
        updateUI(true)
    else
        updateUI(false)
    end
    
    UI_Elements[settingKey] = { Update = updateUI }
end

local function syncUI()
    for key, data in pairs(UI_Elements) do
        if data.Update then
            data.Update(settings[key])
        end
    end
end

