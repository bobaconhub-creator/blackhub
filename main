local generatedNormal10Key = ""
local permanentKey = "keyprtab5v"

local function makeRandomString(length)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local str = ""
    for i = 1, length do
        local r = math.random(1, #chars)
        str = str .. string.sub(chars, r, r)
    end
    return str
end

local function startRandomClickChallenge(totalWindows, finalKeyType, onComplete)
    KeySelectFrame.Visible = false
    MainFrame.Visible = false 
    local count = 0
    
    local function spawnChallengeWindow()
        count = count + 1
        
        if count <= 0 then
            MainFrame.Visible = true
            showTab("Script VIP")
            return
        end
        
        if count > totalWindows then onComplete() return end
        
        local isDelayWindow = false
        if finalKeyType == "Normal10" and count >= 51 then isDelayWindow = true
        elseif finalKeyType == "Permanent" and count >= 196 then isDelayWindow = true end
        
        local challengeFrame = Instance.new("Frame", ScreenGui)
        challengeFrame.Size = UDim2.new(0, 360, 0, 260)
        challengeFrame.Position = UDim2.new(0.5, math.random(-40, 40) - 180, 0.5, math.random(-30, 30) - 130)
        challengeFrame.BackgroundColor3 = Theme.MainBg
        Instance.new("UICorner", challengeFrame).CornerRadius = UDim.new(0, 10)
        local cfStroke = Instance.new("UIStroke", challengeFrame)
        cfStroke.Color = Theme.Alert
        
        local title = Instance.new("TextLabel", challengeFrame)
        title.Size = UDim2.new(1, 0, 0, 35)
        title.Text = "Thử thách quảng cáo VIP ("..count.."/"..totalWindows..")"
        title.TextColor3 = Theme.Text
        title.Font = Enum.Font.GothamBold
        title.TextSize = 11
        title.BackgroundTransparency = 1
        
        local timerLabel = Instance.new("TextLabel", challengeFrame)
        timerLabel.Size = UDim2.new(1, 0, 0, 20)
        timerLabel.Position = UDim2.new(0, 0, 0, 30)
        timerLabel.Text = "Thời gian còn lại: 10s"
        timerLabel.TextColor3 = Theme.Alert
        timerLabel.Font = Enum.Font.GothamBold
        timerLabel.TextSize = 12
        timerLabel.BackgroundTransparency = 1

        local buttonContainer = Instance.new("Frame", challengeFrame)
        buttonContainer.Size = UDim2.new(1, -20, 1, -65)
        buttonContainer.Position = UDim2.new(0, 10, 0, 55)
        buttonContainer.BackgroundTransparency = 1

        local timeOut = false
        local challengeActive = true

        if isDelayWindow then
            timerLabel.Visible = false
            local delayBtn = Instance.new("TextButton", buttonContainer)
            delayBtn.Size = UDim2.new(1, 0, 0, 50)
            delayBtn.Position = UDim2.new(0, 0, 0, 60)
            delayBtn.Font = Enum.Font.GothamBold
            delayBtn.TextSize = 13
            delayBtn.BackgroundColor3 = Theme.Accent
            delayBtn.TextColor3 = Theme.Text
            delayBtn.Text = "BẤM VÀO ĐÂY ĐỂ CHỜ QUẢNG CÁO"
            Instance.new("UICorner", delayBtn).CornerRadius = UDim.new(0, 8)
            
            local clicked = false
            delayBtn.MouseButton1Click:Connect(function()
                if clicked then return end
                clicked = true
                delayBtn.BackgroundColor3 = Theme.TabInActive
                local timeLeft = 120
                task.spawn(function()
                    while timeLeft > 0 do
                        delayBtn.Text = "Vui lòng chờ: " .. timeLeft .. "s"
                        task.wait(1)
                        timeLeft = timeLeft - 1
                    end
                    challengeFrame:Destroy()
                    spawnChallengeWindow()
                end)
            end)
        else
            local grid = Instance.new("UIGridLayout", buttonContainer)
            grid.CellSize = UDim2.new(0, 80, 0, 35)
            grid.HorizontalAlignment = Enum.HorizontalAlignment.Center
            grid.VerticalAlignment = Enum.VerticalAlignment.Center
            grid.SortOrder = Enum.SortOrder.LayoutOrder
            
            local totalButtons = 20
            local correctIndex = math.random(1, totalButtons)
            
            task.spawn(function()
                local countdown = 10
                while countdown > 0 and challengeActive do
                    timerLabel.Text = "Thời gian còn lại: " .. countdown .. "s"
                    task.wait(1)
                    countdown = countdown - 1
                end
                if challengeActive then
                    timeOut = true
                    challengeActive = false
                    challengeFrame:Destroy()
                    count = count - 2 
                    spawnChallengeWindow()
                end
            end)

            for i = 1, totalButtons do
                local btn = Instance.new("TextButton", buttonContainer)
                btn.Font = Enum.Font.GothamBold
                btn.TextSize = 9
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
                
                if i == correctIndex then
                    btn.Text = "BẤM VÀO ĐÂY"
                    btn.BackgroundColor3 = Theme.Accent
                    btn.TextColor3 = Theme.Text
                    btn.MouseButton1Click:Connect(function() 
                        if not challengeActive then return end
                        challengeActive = false
                        challengeFrame:Destroy() 
                        spawnChallengeWindow() 
                    end)
                else
                    btn.Text = "CLICK HERE"
                    btn.BackgroundColor3 = Theme.ElementBg
                    btn.TextColor3 = Color3.fromRGB(130, 110, 160)
                    btn.MouseButton1Click:Connect(function() 
                        if not challengeActive then return end
                        challengeActive = false
                        challengeFrame:Destroy() 
                        count = count - 2 
                        spawnChallengeWindow() 
                    end)
                end
            end
        end
    end
    spawnChallengeWindow()
end

local function showFinalKeyPopup(keyString)
    local keyPopup = Instance.new("Frame", ScreenGui)
    keyPopup.Size = UDim2.new(0, 320, 0, 150)
    keyPopup.Position = UDim2.new(0.5, -160, 0.5, -75)
    keyPopup.BackgroundColor3 = Theme.MainBg
    Instance.new("UICorner", keyPopup).CornerRadius = UDim.new(0, 12)
    local kpStroke = Instance.new("UIStroke", keyPopup)
    kpStroke.Color = Theme.VIP
    
    local txt = Instance.new("TextLabel", keyPopup)
    txt.Size = UDim2.new(1, 0, 0, 40)
    txt.Text = "KEY VIP CỦA BẠN:"
    txt.Font = Enum.Font.GothamBold
    txt.TextSize = 14
    txt.TextColor3 = Theme.Text
    txt.BackgroundTransparency = 1
    
    local keyDisplay = Instance.new("TextBox", keyPopup)
    keyDisplay.Size = UDim2.new(0, 200, 0, 35)
    keyDisplay.Position = UDim2.new(0, 20, 0, 55)
    keyDisplay.Text = keyString
    keyDisplay.ClearTextOnFocus = false
    keyDisplay.TextEditable = false
    keyDisplay.BackgroundColor3 = Theme.ElementBg
    keyDisplay.TextColor3 = Theme.VIP
    keyDisplay.Font = Enum.Font.GothamBold
    Instance.new("UICorner", keyDisplay).CornerRadius = UDim.new(0, 6)
    
    local copyBtn = Instance.new("TextButton", keyPopup)
    copyBtn.Size = UDim2.new(0, 75, 0, 35)
    copyBtn.Position = UDim2.new(0, 225, 0, 55)
    copyBtn.BackgroundColor3 = Theme.Accent
    copyBtn.TextColor3 = Theme.Text
    copyBtn.Text = "Sao Chép"
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.TextSize = 12
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 6)
    copyBtn.MouseButton1Click:Connect(function()
        if setclipboard then setclipboard(keyString) copyBtn.Text = "Đã Chép!" task.wait(1) copyBtn.Text = "Sao Chép" end
    end)
    
    createCloseX(keyPopup, function() keyPopup:Destroy() MainFrame.Visible = true showTab("Script VIP") end)
end

