-- TAB 4: SETTING (CẤU HÌNH THÔNG SỐ)
local SettingScroll = Tabs["Setting"].Scroll

local function createConfigLabel(text, y, fontSize)
    local lbl = Instance.new("TextLabel", SettingScroll)
    lbl.Size = UDim2.new(0,150,0,20)
    lbl.Position = UDim2.new(0,20,0,y)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Theme.Text
    lbl.Text = text
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = fontSize or 14
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    return lbl
end

local function createConfigBox(defaultVal, y, callback)
    local box = Instance.new("TextBox", SettingScroll)
    box.Size = UDim2.new(0,150,0,35)
    box.Position = UDim2.new(0,20,0,y)
    box.BackgroundColor3 = Theme.ElementBg
    box.TextColor3 = Theme.Text
    box.Text = tostring(defaultVal)
    box.TextSize = 14
    Instance.new("UICorner", box).CornerRadius = UDim.new(0,10)
    local s = Instance.new("UIStroke", box)
    s.Color = Color3.fromRGB(70,55,100)
    box.FocusLost:Connect(function() callback(box) end)
    return box
end

createConfigLabel("Speed", 10)
createConfigBox(settings.Speed, 30, function(box)
    local val = tonumber(box.Text)
    if val and val>0 then settings.Speed = val end
end)

createConfigLabel("Hitbox Size", 75)
createConfigBox(settings.HitboxSize, 95, function(box)
    local val = tonumber(box.Text)
    if val and val>0 then settings.HitboxSize = val end
end)

createConfigLabel("Hitbox Transparency", 140, 12)
createConfigBox(settings.HitboxTransparency, 160, function(box)
    local val = tonumber(box.Text)
    if val and val >= 0 and val <= 1 then settings.HitboxTransparency = val
    else box.Text = tostring(settings.HitboxTransparency) end
end)

local healthBtn = Instance.new("TextButton", SettingScroll)
healthBtn.Size = UDim2.new(0,180,0,40)
healthBtn.Position = UDim2.new(0,205,0,30)
