-- Đọc/Ghi File để lưu dữ liệu VIP địa phương
local function saveVIPData()
    if writefile then
        pcall(function()
            writefile("BlackHubVIP_Config.json", httpService:JSONEncode(settings.VIP_Status))
        end)
    end
end

local function loadVIPData()
    if readfile and isfile and isfile("BlackHubVIP_Config.json") then
        local success, data = pcall(function()
            return httpService:JSONDecode(readfile("BlackHubVIP_Config.json"))
        end)
        if success and data then
            if data.IsUnlocked and data.KeyType == "Normal10" then
                local timePassed = os.time() - data.LastSavedTime
                data.TimeRemaining = math.max(0, data.TimeRemaining - timePassed)
                if data.TimeRemaining <= 0 then
                    data.IsUnlocked = false
                    data.KeyType = ""
                end
            end
            settings.VIP_Status = data
        end
    end
end
loadVIPData()

