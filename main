        -- Danh sách chặn riêng biệt cho từng tính năng
        HitboxBlacklist = {["ehfphvg362"] = true},
        ESPBlacklist = {["ehfphvg362"] = true},
        VIP_Status = {
            IsUnlocked = false,
            KeyType = "", 
            TimeRemaining = 0,
            LastSavedTime = os.time()
        }
    }
end
