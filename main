local function createSliderEdit(parent, text, placeholder, defaultVal, settingKey, order)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -20, 0, 50)
    container.BackgroundTransparency = 1
    container.LayoutOrder = order
    
    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, -110, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Colors.Text
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local box = Instance.new("TextBox", container)
    box.Size = UDim2.new(0, 100, 0, 32)
    box.Position = UDim2.new(1, -100, 0.5, -16)
    box.BackgroundColor3 = Colors.Button
    box.PlaceholderText = placeholder
    box.PlaceholderColor3 = Colors.TextDim
    box.Text = tostring(defaultVal)
    box.TextColor3 = Colors.Accent
    box.Font = Enum.Font.GothamBold
    box.TextSize = 14
    Instance.new("UICorner", box).CornerRadius = UDim.new(0,6)
    local stroke = Instance.new("UIStroke", box)
    stroke.Color = Colors.Border
    stroke.Thickness = 1
    
    box.FocusLost:Connect(function()
        local val = tonumber(box.Text)
        if settingKey == "HitboxTransparency" then
            if val and val >= 0 and val <= 1 then settings[settingKey] = val
            else box.Text = tostring(settings[settingKey]) end
        else
            if val and val > 0 then settings[settingKey] = val
            else box.Text = tostring(settings[settingKey]) end
        end
        stroke.Color = Colors.Border
    end)
    box.Focused:Connect(function() stroke.Color = Colors.Accent end)
end

