    stroke.Color = Colors.Border
    stroke.Thickness = 1

    btn.MouseEnter:Connect(function() tweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Button, TextColor3 = Colors.Accent}):Play() stroke.Color = Colors.Accent end)
    btn.MouseLeave:Connect(function() tweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.ScriptBtn, TextColor3 = Colors.Text}):Play() stroke.Color = Colors.Border end)

    btn.MouseButton1Click:Connect(function()
        local success, err = pcall(function() 
