local MainFrame = Instance.new("Frame", ScreenGui)
local originalSize = UDim2.new(0,420,0,320)
MainFrame.Size = originalSize
MainFrame.BackgroundColor3 = Theme.MainBg
MainFrame.Visible = true
MainFrame.Active = true
MainFrame.Draggable = true
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0,12)
MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)

-- Tạo hiệu ứng viền sáng đổi màu liên tục bằng UIStroke + UIGradient
local mainStroke = Instance.new("UIStroke", MainFrame)
mainStroke.Thickness = 2.5 -- Tăng nhẹ độ dày viền để hiệu ứng phát sáng rõ hơn
mainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

local mainGradient = Instance.new("UIGradient", mainStroke)
mainGradient.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Theme.LightPurple),
    ColorSequenceKeypoint.new(0.5, Theme.DarkPurple),
    ColorSequenceKeypoint.new(1, Theme.LightPurple)
})

-- Tạo vòng lặp render xoay chuyển màu viền liên tục (Tím nhạt <-> Tím đậm)
task.spawn(function()
    local t = 0
    while true do
        t = (t + rs.RenderStepped:Wait() * 0.4) % 1 -- Thay đổi hệ số để tăng/giảm tốc độ chạy của viền
        mainGradient.Offset = Vector2.new(math.sin(t * math.pi * 2) * 0.5, math.cos(t * math.pi * 2) * 0.5)
        mainGradient.Rotation = (t * 360)
    end
end)

local isTweening = false
ToggleButton.MouseButton1Click:Connect(function()
    if isTweening then return end
    isTweening = true
    if MainFrame.Visible then
        local closeTween = tweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0,0,0,0)})
        closeTween:Play()
        closeTween.Completed:Connect(function() MainFrame.Visible = false isTweening = false end)
    else
        MainFrame.Size = UDim2.new(0,0,0,0)
        MainFrame.Visible = true
        local openTween = tweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalSize})
        openTween:Play()
        openTween.Completed:Connect(function() isTweening = false end)
    end
end)

local TabBar = Instance.new("Frame", MainFrame)
TabBar.Size = UDim2.new(1,0,0,35)
TabBar.BackgroundColor3 = Theme.TabBg
Instance.new("UICorner", TabBar).CornerRadius = UDim.new(0,8)

local Tabs = {}
local UI_Buttons = {}
local function createTab(name, canvasHeight)
    local tabFrame = Instance.new("Frame")
    tabFrame.Size = UDim2.new(1,0,1,-35)
    tabFrame.Position = UDim2.new(0,0,0,35)
    tabFrame.BackgroundTransparency = 1
    tabFrame.Name = name
    tabFrame.Parent = MainFrame
    tabFrame.Visible = false
    
    local scroll = Instance.new("ScrollingFrame", tabFrame)
    scroll.Size = UDim2.new(1, -10, 1, -10)
    scroll.Position = UDim2.new(0, 5, 0, 5)
    scroll.CanvasSize = UDim2.new(0, 0, 0, canvasHeight or 400)
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = Theme.Accent
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    
    Tabs[name] = { Frame = tabFrame, Scroll = scroll }
end

createTab("Main", 300)
createTab("Vision", 300)
createTab("Script", 750) 
createTab("Setting", 350)
createTab("Script VIP", 450)

local function showTab(name)
    for n, t in pairs(Tabs) do t.Frame.Visible = (n == name) end
    for _, btn in pairs(TabBar:GetChildren()) do
        if btn:IsA("TextButton") then
            btn.BackgroundColor3 = (btn.Text == name) and Theme.TabActive or Theme.TabInActive
            btn.TextColor3 = Theme.Text
        end
    end
end

local function addTabButton(name, order)
    local btn = Instance.new("TextButton", TabBar)
    btn.Size = UDim2.new(0,80,1,0)
    btn.Position = UDim2.new(0, (order-1)*84, 0, 0)
    btn.BackgroundColor3 = Theme.TabInActive
    btn.TextColor3 = Theme.Text
    btn.Text = name
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
    btn.MouseButton1Click:Connect(function() showTab(name) end)
end

addTabButton("Main", 1)
addTabButton("Vision", 2)
addTabButton("Script", 3)
addTabButton("Setting", 4)
addTabButton("Script VIP", 5)

showTab("Main")

local function createToggleButton(tabName, text, y, settingKey, callback)
    local btn = Instance.new("TextButton", Tabs[tabName].Scroll)
    btn.Size = UDim2.new(0,200,0,40)
    btn.Position = UDim2.new(0,20,0,y)
    btn.BackgroundColor3 = Theme.ElementBg
    btn.TextColor3 = Theme.Text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.Text = text.." : "..(settings[settingKey] and "ON" or "OFF")
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,10)
    
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = settings[settingKey] and Theme.Accent or Color3.fromRGB(60,50,80)
    stroke.Thickness = 1.2

    btn.MouseButton1Click:Connect(function()
        settings[settingKey] = not settings[settingKey]
        btn.Text = text.." : "..(settings[settingKey] and "ON" or "OFF")
        stroke.Color = settings[settingKey] and Theme.Accent or Color3.fromRGB(60,50,80)
        callback(settings[settingKey])
    end)

    if settings[settingKey] then
        callback(true)
        btn.Text = text.." : ON"
    end
    UI_Buttons[settingKey] = { Instance = btn, LabelText = text, Stroke = stroke }
end

local function syncUIByFirebase()
    for key, data in pairs(UI_Buttons) do
        if data.Instance and typeof(data.Instance) == "Instance" then
            data.Instance.Text = data.LabelText.." : "..(settings[key] and "ON" or "OFF")
            if data.Stroke then
                data.Stroke.Color = settings[key] and Theme.Accent or Color3.fromRGB(60,50,80)
            end
        end
    end
end

